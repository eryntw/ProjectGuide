@article{Chock2021,
   abstract = {Solar power is a renewable energy source with great potential to help meet increasing global energy demands and reduce our reliance on fossil fuels. However, research is scarce on how solar facilities affect wildlife. With input from professionals in ecology, conservation, and energy, we conducted a research-prioritization process and identified key questions needed to better understand impacts of solar facilities on wildlife. We focused on animal behavior, which can be used to identify population responses before mortality or other fitness consequences are documented. Behavioral studies can also offer approaches to understand the mechanisms leading to negative interactions (e.g., collision, singeing, avoidance) and provide insight into mitigating effects. Here, we review how behavioral responses to solar facilities, including perception, movement, habitat use, and interspecific interactions are priority research areas. Addressing these themes will lead to a more comprehensive understanding of the effects of solar power on wildlife and guide future mitigation.},
   author = {Rachel Y. Chock and Barbara Clucas and Elizabeth K. Peterson and Bradley F. Blackwell and Daniel T. Blumstein and Kathleen Church and Esteban Fernández-Juricic and Gabriel Francescoli and Alison L. Greggor and Paul Kemp and Gabriela M. Pinho and Peter M. Sanzenbacher and Bruce A. Schulte and Pauline Toni},
   doi = {10.1111/CSP2.319},
   issn = {2578-4854},
   issue = {2},
   journal = {Conservation Science and Practice},
   keywords = {animal behavior,concentrating solar power (CSP),conservation,conservation behavior,photovoltaic (PV) cells,research prioritization process,scale solar energy (USSE),solar power,utility},
   month = {2},
   pages = {e319},
   publisher = {John Wiley \& Sons, Ltd},
   title = {Evaluating potential effects of solar power facilities on wildlife from an animal behavior perspective},
   volume = {3},
   url = {/doi/pdf/10.1111/csp2.319 https://onlinelibrary.wiley.com/doi/abs/10.1111/csp2.319 https://conbio.onlinelibrary.wiley.com/doi/10.1111/csp2.319},
   year = {2021}
}
